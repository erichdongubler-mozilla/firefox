{
  "background": {
    "color": {
      "inactive": {
        "value": {
          "nativeTheme": "-moz-headerbarinactive",
          "default": "transparent"
        }
      }
    }
  },
  "text": {
    "color": {
      "@base": {
        "value": {
          "nativeTheme": "-moz-headerbartext",
          "default": "{text.color.@base}"
        }
      },
      "inactive": {
        "value": {
          "nativeTheme": "-moz-headerbarinactivetext",
          "default": "{text.color.deemphasized}"
        }
      }
    }
  }
}
