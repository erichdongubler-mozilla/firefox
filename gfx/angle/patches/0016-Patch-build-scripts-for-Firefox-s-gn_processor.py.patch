From d1a7429512a6e904dcbfff390c20c2ade66f96b3 Mon Sep 17 00:00:00 2001
From: Jamie Nicol <jnicol@mozilla.com>
Date: Fri, 1 May 2026 10:56:48 +0100
Subject: [PATCH] Patch build scripts for Firefox's gn_processor.py

When vendored into Firefox, the script gn_processor.py is used to
generate moz.build files from ANGLE's GN build scripts.

This relies upon Firefox's vendored fork of Chromium's "build" repo,
which we explicitly opt in to building ANGLE with by setting the
`angle_has_build` GN arg in `gn-configs/angle.json`. In Firefox, this
repo is located at `third_party/chromium/build`. We must therefore
replace all references to `//build/` with `//chromium/build` in the GN
files.

The `//dotfile_settings.gni` import must also be replaced with
`//angle/dotfile_settings.gni` due to gn_processor.py executing in the
parent directory (i.e `third_party`, rather than `third_party/angle`).

Lastly, we comment out a couple dependencies on chromium's "testing"
repo, which ANGLE assumes is available due to enabling
`angle_has_build`, but we opted not to vendor.
---
 .gn                                   | 14 ++++----
 BUILD.gn                              | 24 ++++++-------
 android/angle_apk.gni                 |  2 +-
 gni/angle.gni                         | 50 +++++++++++++--------------
 src/compiler/translator/ir/BUILD.gn   |  2 +-
 src/libANGLE/renderer/gl/BUILD.gn     |  4 +--
 src/libANGLE/renderer/metal/BUILD.gn  |  2 +-
 src/libANGLE/renderer/vulkan/BUILD.gn |  2 +-
 8 files changed, 50 insertions(+), 50 deletions(-)

diff --git a/.gn b/.gn
index cb77c2a94f..f9b4bbb67a 100644
--- a/.gn
+++ b/.gn
@@ -7,11 +7,11 @@
 # As a result this file will only affect stand-alone ANGLE builds,
 # not chromium builds.
 
-import("//build/dotfile_settings.gni")
-import("//dotfile_settings.gni")
+import("//chromium/build/dotfile_settings.gni")
+import("//angle/dotfile_settings.gni")
 
 # Location of the build configuration file.
-buildconfig = "//build/config/BUILDCONFIG.gn"
+buildconfig = "//chromium/build/config/BUILDCONFIG.gn"
 
 # The python interpreter to use by default. On Windows, this will look
 # for python3.exe and python3.bat.
@@ -29,10 +29,10 @@ script_executable = "python3"
 exec_script_allowlist = angle_dotfile_settings.exec_script_allowlist +
                         build_dotfile_settings.exec_script_allowlist +
                         [
-                          "//build/config/sysroot.gni",
-                          "//build/config/win/BUILD.gn",
-                          "//build/config/win/visual_studio_version.gni",
-                          "//build/gn_helpers.py",
+                          "//chromium/build/config/sysroot.gni",
+                          "//chromium/build/config/win/BUILD.gn",
+                          "//chromium/build/config/win/visual_studio_version.gni",
+                          "//chromium/build/gn_helpers.py",
                           "//build_overrides/build.gni",
                         ]
 
